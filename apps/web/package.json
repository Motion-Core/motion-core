{
	"name": "@motion-core/docs-template",
	"version": "0.1.1",
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.53.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.1.17",
		"@typescript-eslint/eslint-plugin": "^8.56.1",
		"@typescript-eslint/parser": "^8.56.1",
		"@types/three": "^0.182.0",
		"eslint": "^10.0.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.15.0",
		"globals": "^17.4.0",
		"mdsvex": "^0.12.6",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.0",
		"rehype-pretty-code": "^0.14.1",
		"shiki": "^4.0.1",
		"svelte": "^5.53.2",
		"svelte-check": "^4.3.4",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.1",
		"vite": "^7.2.7",
		"vitest": "^4.0.18",
		"wrangler": "^4.72.0"
	},
	"private": true,
	"scripts": {
		"build:registry": "bun ../../scripts/build-registry.ts",
		"docs:sync": "bun ../../scripts/sync-docs.ts",
		"predev": "bun ../../scripts/build-registry.ts && bun run docs:sync && bun ../../scripts/validate-navigation.ts",
		"dev": "vite dev",
		"prebuild": "bun ../../scripts/build-registry.ts && bun run docs:sync",
		"build": "vite build",
		"prepreview": "bun ../../scripts/build-registry.ts && bun run docs:sync",
		"preview": "vite preview",
		"preview:cf": "bun run build && wrangler dev",
		"preview:cf:remote": "bun run build && wrangler dev --remote",
		"deploy": "bun run build && wrangler deploy",
		"cf-typegen": "wrangler types",
		"prepare": "svelte-kit sync || echo ''",
		"precheck": "bun ../../scripts/build-registry.ts",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"precheck:watch": "bun ../../scripts/build-registry.ts",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write ."
	},
	"type": "module",
	"dependencies": {
		"@fontsource/inter": "^5.2.8",
		"@mediapipe/tasks-vision": "^0.10.22-rc.20250304",
		"@takumi-rs/image-response": "1.0.0-rc.12",
		"@threlte/core": "^8.3.1",
		"@threlte/extras": "^9.7.1",
		"carbon-icons-svelte": "^13.9.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"gsap": "^3.14.2",
		"motion-core": "workspace:*",
		"ogl": "^1.0.11",
		"tailwind-merge": "^3.5.0",
		"three": "^0.182.0"
	}
}

## Props

### AsciiRenderer

<ApiTable
	headers={["Prop", "Type", "Default"]}
	keys={["prop", "type", "default"]}
	data={[
		{
			prop: "src",
			type: "string",
			default: "—",
			description: "URL of the image to be rendered as ASCII art.",
		},
		{
			prop: "density",
			type: "number",
			default: "25",
			description:
				"Grid density of the ASCII characters. Higher values mean more characters.",
		},
		{
			prop: "strength",
			type: "number",
			default: "3.0",
			description: "Intensity of the ASCII character generation threshold.",
		},
		{
			prop: "color",
			type: 'string | number | [number, number, number] | { r: number; g: number; b: number }',
			default: '"#00ff00"',
			description: "Color of the ASCII characters.",
		},
			{
				prop: "backgroundColor",
				type: 'string | number | [number, number, number] | { r: number; g: number; b: number }',

## Props

### FluidImageReveal

<ApiTable
	headers={["Prop", "Type", "Default"]}
	keys={["prop", "type", "default"]}
	data={[
		{
			prop: "baseImage",
			type: "string",
			default: "—",
			description: "URL of the base image shown by default.",
		},
		{
			prop: "revealImage",
			type: "string",
			default: "—",
			description: "URL of the image revealed through the fluid mask.",
		},
		{
			prop: "dissipation",
			type: "number",
			default: "0.96",
			description:
				"Dissipation factor for the reveal mask. Lower values make reveal trails fade faster.",
		},
		{
			prop: "pointerSize",
			type: "number",
			default: "0.005",
			description: "Radius of the pointer influence (splat size).",
		},
		{
			prop: "velocityDissipation",
			type: "number",
			default: "0.96",
			description:
				"Dissipation factor for fluid velocity. Lower values make motion settle faster.",
		},
		{
			prop: "pressureIterations",
			type: "number",
			default: "10",
			description:
				"Number of Jacobi iterations for pressure solving. Higher values improve stability at extra cost.",
		},
		{
			prop: "blendSoftness",
			type: "number",
			default: "0.22",
			description:
				"Softness of the transition between base and reveal image. Higher values make edges smoother.",
		},
		{
			prop: "class",
			type: "string",
			default: '""',
			description: "Additional CSS classes for the container.",
		},
	]}
/>

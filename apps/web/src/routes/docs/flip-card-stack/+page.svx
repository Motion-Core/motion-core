## Props

<ApiTable
	headers={["Prop", "Type", "Default"]}
	keys={["prop", "type", "default"]}
	data={[
		{
			prop: "items",
			type: "T[]",
			default: "—",
			description: "Array of items rendered as stack cards.",
		},
		{
			prop: "children",
			type: "Snippet<[T, number]>",
			default: "—",
			description: "Snippet used to render each card content.",
		},
		{
			prop: "stackOffset",
			type: "number",
			default: "8",
			description: "Vertical spacing between cards in the stack.",
		},
		{
			prop: "stackRotation",
			type: "number",
			default: "-10",
			description: "Rotation step (deg) for cards below the top card.",
		},
		{
			prop: "dragThreshold",
			type: "number",
			default: "80",
			description:
				"Minimum drag distance required to move the top card to the back.",
		},
		{
			prop: "duration",
			type: "number",
			default: "0.3",
			description: "Animation duration in seconds.",
		},
		{
			prop: "ease",
			type: "string",
			default: '"power2.out"',
			description: "GSAP ease string.",
		},
		{
			prop: "class",

## Props

### FluidSimulation

<ApiTable
	headers={["Prop", "Type", "Default"]}
	keys={["prop", "type", "default"]}
	data={[
		{
			prop: "dissipation",
			type: "number",
			default: "0.96",
			description:
				"Dissipation factor for the fluid density. Lower values make the fluid disappear faster.",
		},
		{
			prop: "pointerSize",
			type: "number",
			default: "0.005",
			description: "Radius of the pointer influence (splat size).",
		},
		{
			prop: "color",
			type: "string | number | [number, number, number] | { r: number; g: number; b: number }",
			default: '"#ff6900"',
			description:
				"Color of the fluid splat. Accepts string, number, RGB tuple, or { r, g, b } object.",
		},
		{
			prop: "velocityDissipation",
			type: "number",
			default: "0.96",
			description:
				"Dissipation factor for the fluid velocity. Lower values make the fluid stop moving faster.",
		},
		{
			prop: "pressureIterations",
			type: "number",
			default: "10",
			description:
				"Number of Jacobi iterations for the pressure solver. More iterations result in more accurate and stable simulation.",
		},
		{
			prop: "class",
			type: "string",
			default: '""',
			description: "Additional CSS classes for the container.",
		},
	]}
/>

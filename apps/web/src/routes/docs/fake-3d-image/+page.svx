## Props

### Fake3DImage

<ApiTable
	headers={["Prop", "Type", "Default"]}
	keys={["prop", "type", "default"]}
	data={[
		{
			prop: "colorSrc",
			type: "string",
			default: "—",
			description: "Path to the original color image.",
		},
		{
			prop: "depthSrc",
			type: "string",
			default: "—",
			description: "Path to the grayscale depth map image.",
		},
		{
			prop: "xThreshold",
			type: "number",
			default: "8",
			description: "Horizontal displacement threshold.",
		},
			{
				prop: "yThreshold",
				type: "number",
				default: "8",
				description: "Vertical displacement threshold.",
			},
			{
				prop: "sensitivity",
				type: "number",
				default: "0.125",
				description: "Pointer sensitivity multiplier for parallax motion.",
			},
			{
				prop: "class",
				type: "string",
